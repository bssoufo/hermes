# Local-only env template -- copy to .env.local (gitignored) and fill in.
# Used only when running with `-f docker-compose.local.yml`.

# -- Required for local smoke test -------------------------------------
# Any random string is fine locally. openssl rand -hex 32 if you want entropy.
API_SERVER_KEY=dev-local-token-change-me

# Your real OpenAI key (the smoke test calls gpt-4o).
OPENAI_API_KEY=

# -- GoHighLevel Private Integration Token ----------------------------
# Create in: GHL sub-account -> Settings -> Private Integrations -> New Token.
# Minimum scopes needed for the smoke test:
#   - contacts.readonly, contacts.write
#   - conversations.readonly, conversations.write, conversations/message.write
#   - calendars.readonly, calendars/events.readonly, calendars/events.write
#   - opportunities.readonly
GHL_PIT_TOKEN=pit-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: pin the MCP calls to one specific sub-account if your PIT has multiple.
# GHL_LOCATION_ID=

# -- Optional: contact ID to use for the SMS-draft smoke test ----------
# Leave blank to skip that step. Use a TEST contact -- the script still
# asks the LLM to DRAFT, not send. But better safe than sorry.
SMOKE_TEST_CONTACT_ID=

# -- Local dev overrides (usually unnecessary) -------------------------
# GATEWAY_ALLOWED_USERS=local-dev
# LOG_LEVEL=DEBUG
