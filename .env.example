# Hermes Agent on Elestio -- environment template.
# Populate values in the Elestio pipeline's "Environment Variables" tab;
# Elestio writes them to /opt/app/.env on the VM at deploy time.

# -- Required: API gateway ---------------------------------------------
# Bearer token for the OpenAI-compatible API. MANDATORY for non-loopback bind.
# Generate: openssl rand -hex 32
API_SERVER_KEY=

# Optional: CORS allowlist for browser clients (comma-separated origins).
API_SERVER_CORS_ORIGINS=

# -- Required: authorization -------------------------------------------
# Comma-separated user IDs permitted to use the gateway across platforms.
# Leave empty + do NOT set GATEWAY_ALLOW_ALL_USERS in production.
GATEWAY_ALLOWED_USERS=

# -- Required: model provider (OpenRouter) -----------------------------
# OpenRouter is the only headless-friendly path: just set the key.
# OpenAI-direct (HERMES_INFERENCE_PROVIDER=openai-codex) requires
# interactive `hermes auth` browser flow, unusable on CI/CD VMs.
# Get a key at https://openrouter.ai (supports 200+ models incl. GPT, Claude).
OPENROUTER_API_KEY=
HERMES_INFERENCE_PROVIDER=openrouter
# Optional: pin a default model. OpenRouter model-name convention:
# "openai/gpt-4o", "anthropic/claude-3.5-sonnet", "google/gemini-2.0-flash".
# HERMES_DEFAULT_MODEL=openai/gpt-4o

# -- Optional: messaging integrations (add as needed) ------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# SLACK_BOT_TOKEN=

# -- Optional: STT (voice transcription) and other providers -----------
# OpenAI key is used ONLY for Whisper STT here, not for chat.
# VOICE_TOOLS_OPENAI_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# -- GoHighLevel integration (for the SDR skill) -----------------------
# Private Integration Token, created per sub-account in GHL Settings.
# Referenced from storage/hermes/config.yaml via ${GHL_PIT_TOKEN}.
# GHL_PIT_TOKEN=
# Optional: pin calls to a specific sub-account when the PIT is broad-scoped.
# GHL_LOCATION_ID=

# Shared secret used by the Hermes webhook route to validate that
# incoming POSTs to /webhooks/ghl-inbound were signed by GHL. Generate
# with: openssl rand -hex 32. Configure the same value as the HMAC
# secret on the GHL Workflow -> Custom Webhook action.
# Temporary fallback for early testing: set to "INSECURE_NO_AUTH" to
# accept unsigned webhooks (NEVER in production).
# GHL_WEBHOOK_SECRET=

# -- Optional: runtime tuning ------------------------------------------
# LOG_LEVEL=INFO
